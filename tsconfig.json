{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "paths": {
      "@lamplight/ui": ["./packages/ui/src/index.ts"],
      "@lamplight/ui/*": ["./packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "**/node_modules", "**/.next", "**/dist"]
}
