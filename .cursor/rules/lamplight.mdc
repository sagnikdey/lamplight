| 24px spacing | `var(--spacing-xl)` |
| 32px spacing | `var(--spacing-2xl)` |
| 48px spacing | `var(--spacing-3xl)` |
| Input radius | `rounded-[var(--border-radius-md)]` |
| Card radius | `rounded-[var(--border-radius-lg)]` |
| Pill radius | `rounded-[var(--border-radius-full)]` |
| Heading font | `font-[family-name:var(--font-heading)]` |
| Body font | `font-[family-name:var(--font-body)]` |
| Mono font | `font-[family-name:var(--font-mono)]` |
| Focus ring | `focus-visible:ring-[length:var(--focus-ring-width)] focus-visible:ring-offset-[length:var(--focus-ring-offset)] focus-visible:ring-[var(--color-border-focus)]` |
