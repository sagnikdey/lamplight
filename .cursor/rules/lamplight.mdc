## 12. Building new components — the required pattern

Every new component must follow this exact structure:

```tsx
// 1. Import order
import * as React from 'react';
import { SomeRadixPrimitive } from '@radix-ui/react-something';
import { SomeLucideIcon } from 'lucide-react';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@lamplight/ui';   // or '../../lib/cn' from within packages/ui

// 2. cva for variant axes — map directly to Figma Type × State × Size axes
const componentVariants = cva(
  // Base classes — use token vars only
  ['inline-flex items-center', 'transition-colors duration-150'],
  {
    variants: {
      variant: {
        primary:   'bg-[var(--color-surface-action)] text-[color:var(--color-text-on-action)]',
        secondary: 'bg-transparent border border-[color:var(--color-border-action)]',
      },
      size: {
        md: 'px-[var(--spacing-xl)] py-[var(--spacing-lg)]',
        sm: 'px-[var(--spacing-lg)] py-[var(--spacing-sm)]',
      },
    },
    defaultVariants: { variant: 'primary', size: 'md' },
  }
);

// 3. Props interface extends HTML element + VariantProps
export interface NewComponentProps
  extends React.HTMLAttributes<HTMLDivElement>,
    VariantProps<typeof componentVariants> {
  asChild?: boolean;
}

// 4. forwardRef always
export const NewComponent = React.forwardRef<HTMLDivElement, NewComponentProps>(
  ({ variant, size, className, ...props }, ref) => (
    <div
      ref={ref}
      className={cn(componentVariants({ variant, size }), className)}
      {...props}
    />
  )
);
NewComponent.displayName = 'NewComponent';

// 5. Export types alongside the component
export type { NewComponentProps };
```

**Checklist for every new component:**
- [ ] Uses `cva` for variants — no conditional className template literals
- [ ] Uses `cn()` for class merging — never string concatenation
- [ ] Uses `React.forwardRef`
- [ ] Has `displayName`
- [ ] References only `--color-*`, `--spacing-*`, `--border-radius-*`, `--font-*` vars
- [ ] Has zero inline `style` props for visual properties
- [ ] Has `aria-*` attributes for accessibility
- [ ] Exported from `packages/ui/src/index.ts`
- [ ] Has a `.stories.tsx` with all variant axes, dark mode, and focus ring stories

---

## 13. cn() — always use it, never concatenate

```tsx
// ✅ Correct
className={cn(
  'base classes',
  isActive && 'active classes',
  variant === 'outline' && 'outline classes',
  className   // always spread className last so consumers can override
)}

// ❌ Wrong — defeats tailwind-merge conflict resolution
className={`base ${isActive ? 'active' : ''} ${className}`}
className={'base ' + className}
```

---

## 14. Icons — always via IconWrapper or explicit size

Always use Lucide. Never set size via CSS width/height — use the `size` prop or `IconWrapper`.

```tsx
// ✅ Correct — standalone with explicit prop
<Search size={16} className="text-[color:var(--color-icon-action)]" aria-hidden />

// ✅ Correct — via IconWrapper for consistent sizing + semantics
<IconWrapper icon={<Search />} size="sm" className="text-[color:var(--color-icon-action)]" />

// ❌ Wrong — CSS sizing bypasses the wrapper contract
<Search className="w-4 h-4" />
<Search style={{ width: 16, height: 16 }} />
```

---

## 15. Next.js App Router patterns

```tsx
// Server components (default) — no 'use client', no useState/useEffect
// Use for: page layouts, data fetching, static content

// Client components — add 'use client' only when needed
'use client'; // ← required for: useState, useEffect, event handlers, Radix components

// Fonts — always via next/font, never @import in CSS
import { Open_Sans, Merriweather } from 'next/font/google';
// The variables --brand-font-family-body/headings are set in layout.tsx already
// Never import fonts again — just use the CSS var

// Images — always next/image
import Image from 'next/image';

// Links — always next/link, use asChild on Button to wrap
import Link from 'next/link';
<Button asChild><Link href="/path">Label</Link></Button>

// Never use <a> tags for internal navigation
// Never use <img> tags — always <Image>
```

